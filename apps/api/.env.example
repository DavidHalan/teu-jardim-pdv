# Copie para .env e ajuste conforme necessário.
# Runtime da aplicação: role pdv_app (não-superuser; sem UPDATE/DELETE em audit_logs — ADR-0025).
DATABASE_URL=postgresql://pdv_app:pdv_app@localhost:5432/teu_jardim?schema=public
# Migrations/CLI do Prisma: role pdv (owner). Sem esta var, o CLI cai para DATABASE_URL.
MIGRATION_DATABASE_URL=postgresql://pdv:pdv@localhost:5432/teu_jardim?schema=public
PORT=3000
# Origem do frontend (CORS) — Vite dev server
WEB_ORIGIN=http://localhost:5173
# Segredo do JWT — TROCAR em produção (gerar com: openssl rand -base64 48)
JWT_SECRET=dev-only-change-me-please-0000000000000000
# Chave do print-service (poll/ACK da fila de cupons) — TROCAR em produção
PRINT_SERVICE_API_KEY=dev-print-key-change-me

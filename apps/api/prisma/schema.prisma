// Schema do teu-jardim-pdv — traduz docs/architecture/erd.md.
// Prosa/enum values em EN (código). Dinheiro = Decimal(12,2) (ADR-0004).
// IDs = uuid. Ver docs/BRD.md para as regras (RB-xxx).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------------------
// Enums (espelham packages/shared)
// ----------------------------------------------------------------------------

enum Role {
  EMPLOYEE
  CASHIER
  ADMIN
}

enum TabType {
  WRISTBAND
  COMANDA
  TABLE
}

enum AccountStatus {
  OPEN
  PAID
  CANCELED
}

enum ProductType {
  UNIT
  WEIGHED
}

enum KdsStatus {
  PENDING
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELED
}

enum CashMovementType {
  SALE_RECEIPT
  WITHDRAWAL
  SUPPLY
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT
  DEBIT
}

enum OpenClosedStatus {
  OPEN
  CLOSED
}

enum PaymentStatus {
  PENDING
  SETTLED
  CANCELED
}

// ----------------------------------------------------------------------------
// Core
// ----------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(EMPLOYEE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")

  openedSessions   BusinessSession[]
  operatedRegisters Register[]
  cashMovements    CashMovement[]
  openedAccounts   Account[]
  placedItems      AccountItem[]
  appliedDiscounts Discount[]
  itemTransfers    ItemTransfer[]
  createdGroups    AccountGroup[]
  createdPayments  Payment[]
  stockMovements   StockMovement[]
  auditLogs        AuditLog[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  eventType  String   @map("event_type")
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([createdAt])
  @@map("audit_logs")
}

model Configuration {
  id           String   @id @default(uuid())
  businessName String   @map("business_name")
  settings     Json?
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("configuration")
}

// ----------------------------------------------------------------------------
// PDV
// ----------------------------------------------------------------------------

model Category {
  id       String  @id @default(uuid())
  name     String
  active   Boolean @default(true)
  sortOrder Int    @default(0) @map("sort_order")

  products Product[]

  @@map("categories")
}

model Product {
  id               String      @id @default(uuid())
  categoryId       String      @map("category_id")
  name             String
  price            Decimal     @db.Decimal(12, 2)
  type             ProductType @default(UNIT)
  usesObservations Boolean     @default(false) @map("uses_observations")
  kdsStationId     String?     @map("kds_station_id")
  active           Boolean     @default(true)
  createdAt        DateTime    @default(now()) @map("created_at")

  category     Category             @relation(fields: [categoryId], references: [id])
  kdsStation   Station?             @relation(fields: [kdsStationId], references: [id])
  observations ProductObservation[]
  items        AccountItem[]
  stockMoves   StockMovement[]

  @@index([categoryId])
  @@map("products")
}

model ProductObservation {
  id        String @id @default(uuid())
  productId String @map("product_id")
  name      String
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_observations")
}

model BusinessSession {
  id        String           @id @default(uuid())
  name      String
  status    OpenClosedStatus @default(OPEN)
  openedById String          @map("opened_by")
  openedAt  DateTime         @default(now()) @map("opened_at")
  closedAt  DateTime?        @map("closed_at")

  openedBy  User           @relation(fields: [openedById], references: [id])
  registers Register[]
  accounts  Account[]
  groups    AccountGroup[]

  @@map("business_sessions")
}

model Register {
  id                String           @id @default(uuid())
  businessSessionId String           @map("business_session_id")
  operatorId        String           @map("operator_id")
  openingAmount     Decimal          @map("opening_amount") @db.Decimal(12, 2)
  status            OpenClosedStatus @default(OPEN)
  openedAt          DateTime         @default(now()) @map("opened_at")
  closedAt          DateTime?        @map("closed_at")
  expectedAmount    Decimal?         @map("expected_amount") @db.Decimal(12, 2)
  countedAmount     Decimal?         @map("counted_amount") @db.Decimal(12, 2)
  difference        Decimal?         @db.Decimal(12, 2)

  businessSession BusinessSession @relation(fields: [businessSessionId], references: [id])
  operator        User            @relation(fields: [operatorId], references: [id])
  movements       CashMovement[]
  payments        Payment[]

  @@index([businessSessionId])
  @@map("registers")
}

model CashMovement {
  id         String           @id @default(uuid())
  registerId String           @map("register_id")
  type       CashMovementType
  amount     Decimal          @db.Decimal(12, 2)
  reason     String?
  userId     String           @map("user_id")
  createdAt  DateTime         @default(now()) @map("created_at")

  register Register @relation(fields: [registerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([registerId])
  @@map("cash_movements")
}

// ----------------------------------------------------------------------------
// Contas de consumo (conta = sessão — ADR-0003)
// ----------------------------------------------------------------------------

model Account {
  id                String        @id @default(uuid())
  businessSessionId String        @map("business_session_id")
  tabType           TabType       @map("tab_type")
  number            Int
  status            AccountStatus @default(OPEN)
  openedById        String        @map("opened_by")
  openedAt          DateTime      @default(now()) @map("opened_at")
  closedAt          DateTime?     @map("closed_at")
  subtotal          Decimal       @default(0) @db.Decimal(12, 2)
  discountTotal     Decimal       @default(0) @map("discount_total") @db.Decimal(12, 2)
  total             Decimal       @default(0) @db.Decimal(12, 2)

  businessSession BusinessSession      @relation(fields: [businessSessionId], references: [id])
  openedBy        User                 @relation(fields: [openedById], references: [id])
  items           AccountItem[]
  discounts       Discount[]
  groupMembership AccountGroupMember?
  transfersFrom   ItemTransfer[]       @relation("TransferFrom")
  transfersTo     ItemTransfer[]       @relation("TransferTo")

  // RB-003: no máximo 1 conta OPEN por (tab_type, number).
  // Prisma não expressa índice único PARCIAL; ele é adicionado via SQL na migration:
  //   CREATE UNIQUE INDEX uniq_open_account ON accounts (tab_type, number) WHERE status = 'OPEN';
  @@index([tabType, number])
  @@index([status])
  @@map("accounts")
}

model AccountItem {
  id          String    @id @default(uuid())
  accountId   String    @map("account_id")
  productId   String    @map("product_id")
  quantity    Int       @default(1)
  weightGrams Int?      @map("weight_grams")
  unitPrice   Decimal   @map("unit_price") @db.Decimal(12, 2)
  lineTotal   Decimal   @map("line_total") @db.Decimal(12, 2)
  kdsStatus   KdsStatus @default(PENDING) @map("kds_status")
  placedById  String    @map("placed_by")
  placedAt    DateTime  @default(now()) @map("placed_at")
  canceledReason String? @map("canceled_reason")

  account      Account                  @relation(fields: [accountId], references: [id])
  product      Product                  @relation(fields: [productId], references: [id])
  placedBy     User                     @relation(fields: [placedById], references: [id])
  observations AccountItemObservation[]
  transfers    ItemTransfer[]

  @@index([accountId])
  @@index([kdsStatus])
  @@map("account_items")
}

model AccountItemObservation {
  id            String  @id @default(uuid())
  accountItemId String  @map("account_item_id")
  observationId String? @map("observation_id")
  text          String

  accountItem AccountItem @relation(fields: [accountItemId], references: [id])

  @@map("account_item_observations")
}

model Discount {
  id         String       @id @default(uuid())
  accountId  String       @map("account_id")
  type       DiscountType
  value      Decimal      @db.Decimal(12, 2)
  appliedById String      @map("applied_by")
  reason     String?
  createdAt  DateTime     @default(now()) @map("created_at")

  account   Account @relation(fields: [accountId], references: [id])
  appliedBy User    @relation(fields: [appliedById], references: [id])

  @@index([accountId])
  @@map("discounts")
}

model ItemTransfer {
  id            String   @id @default(uuid())
  accountItemId String   @map("account_item_id")
  fromAccountId String   @map("from_account_id")
  toAccountId   String   @map("to_account_id")
  userId        String   @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")

  accountItem AccountItem @relation(fields: [accountItemId], references: [id])
  fromAccount Account     @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   Account     @relation("TransferTo", fields: [toAccountId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@map("item_transfers")
}

// ----------------------------------------------------------------------------
// KDS
// ----------------------------------------------------------------------------

model Station {
  id     String  @id @default(uuid())
  name   String
  active Boolean @default(true)

  products Product[]

  @@map("stations")
}

// ----------------------------------------------------------------------------
// Pagamentos (Payment + PaymentTender + AccountGroup — ADR-0007)
// ----------------------------------------------------------------------------

model AccountGroup {
  id                String   @id @default(uuid())
  businessSessionId String   @map("business_session_id")
  createdById       String   @map("created_by")
  createdAt         DateTime @default(now()) @map("created_at")

  businessSession BusinessSession      @relation(fields: [businessSessionId], references: [id])
  createdBy       User                 @relation(fields: [createdById], references: [id])
  members         AccountGroupMember[]
  payment         Payment?

  @@map("account_groups")
}

model AccountGroupMember {
  accountGroupId String @map("account_group_id")
  accountId      String @unique @map("account_id") // RB-039: conta em ≤1 grupo

  accountGroup AccountGroup @relation(fields: [accountGroupId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@id([accountGroupId, accountId])
  @@map("account_group_members")
}

model Payment {
  id             String        @id @default(uuid())
  accountGroupId String        @unique @map("account_group_id")
  registerId     String        @map("register_id")
  total          Decimal       @db.Decimal(12, 2)
  status         PaymentStatus @default(PENDING)
  createdById    String        @map("created_by")
  createdAt      DateTime      @default(now()) @map("created_at")

  accountGroup AccountGroup    @relation(fields: [accountGroupId], references: [id])
  register     Register        @relation(fields: [registerId], references: [id])
  createdBy    User            @relation(fields: [createdById], references: [id])
  tenders      PaymentTender[]

  @@map("payments")
}

model PaymentTender {
  id        String        @id @default(uuid())
  paymentId String        @map("payment_id")
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("payment_tenders")
}

// ----------------------------------------------------------------------------
// Estoque (simples — RB-045, RB-046)
// ----------------------------------------------------------------------------

model StockMovement {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  type      String // IN | OUT | ADJUST
  quantity  Decimal  @db.Decimal(12, 3)
  reason    String?
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@map("stock_movements")
}

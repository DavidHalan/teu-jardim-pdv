# Copie para .env e ajuste conforme necessário.
# API local (o serviço fala SEMPRE pela API — nunca toca o Postgres).
API_URL=http://localhost:3000
# Mesma chave configurada no .env da API — TROCAR em produção.
PRINT_SERVICE_API_KEY=dev-print-key-change-me
# Intervalo de poll da fila (ADR-0020).
POLL_INTERVAL_MS=2000
# Driver default: console (render no terminal). Driver da térmica (Bematech MP-100S TH) entra no deploy.
PRINTER_DRIVER=console
# Roteamento A/B por estação (JSON; chave = stationId ou nome). Vazio = tudo no default.
# Ex.: STATION_PRINTERS={"Sucos":"bematech-a","Caixa":"bematech-b"}
STATION_PRINTERS={}
